{
    "name": "@ghostchu/openai-content-audit",
    "private": true,
    "version": "0.0.0",
    "devDependencies": {
        "flarum-webpack-config": "^3.0.0",
        "webpack": "^5.88.0",
        "webpack-cli": "^5.0.0",
        "prettier": "^3.0.0",
        "@flarum/prettier-config": "^2.0.0",
        "flarum-tsconfig": "^2.0.0",
        "typescript": "^5.0.0",
        "typescript-coverage-report": "^0.8.0",
        "@flarum/jest-config": "^2.0.0"
    },
    "scripts": {
        "dev": "webpack --mode development --watch",
        "build": "webpack --mode production",
        "analyze": "cross-env ANALYZER=true npm run build",
        "format": "prettier --write src",
        "format-check": "prettier --check src",
        "clean-typings": "npx rimraf dist-typings && mkdir dist-typings",
        "build-typings": "npm run clean-typings && ([ -e src/@types ] && cp -r src/@types dist-typings/@types || true) && tsc && npm run post-build-typings",
        "post-build-typings": "find dist-typings -type f -name '*.d.ts' -print0 | xargs -0 sed -i 's,../src/@types,@types,g'",
        "check-typings": "tsc --noEmit --emitDeclarationOnly false",
        "check-typings-coverage": "typescript-coverage-report",
        "test": "yarn node --experimental-vm-modules $(yarn bin jest)"
    },
    "prettier": "@flarum/prettier-config",
    "type": "module"
}
